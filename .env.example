# Copy this file to .env.local and fill in values for your environment.

# Base URL of the NestJS backend (no trailing slash).
# Socket.IO connects to ${VITE_API_URL}/orders namespace.
# REST API is at ${VITE_API_URL}/api/v1/...
VITE_API_URL=http://192.168.254.124:8000

# UUID of the store this frontend instance belongs to.
# After running `bun run seed:stores` on the backend, find the UUID via:
#   SELECT id, name FROM "Store";
# or GET /api/v1/stores (if the endpoint exists).
VITE_STORE_ID=your-store-uuid-here
